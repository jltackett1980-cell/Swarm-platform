#!/usr/bin/env python3
import os, sys, json, time, random
from pathlib import Path
from datetime import datetime

home = Path.home()
CONFIGS_FILE = home / "organism_templates" / "domain_configs.json"
STATE_FILE = home / "organism_state.json"

def load_state():
    try:
        return json.loads(STATE_FILE.read_text())
    except:
        return {"cycles": 0, "projects_created": 0}

def save_state(state):
    STATE_FILE.write_text(json.dumps(state, indent=2))

def load_configs():
    if CONFIGS_FILE.exists():
        return json.loads(CONFIGS_FILE.read_text())
    return {}

def build_backend(domain_id, cfg):
    """Build a real backend using actual domain fields from config"""
    entity = cfg.get("entity", "Record")
    entities = cfg.get("entities", "Records")
    fields = cfg.get("fields", [])
    table_name = entities.lower().replace(" ", "_")

    # Build CREATE TABLE with real domain columns
    col_defs = []
    for field in fields:
        fname, flabel, ftype = field[0], field[1], field[2]
        if ftype == "number":
            col_defs.append(f'"{fname}" REAL')
        elif ftype == "date":
            col_defs.append(f'"{fname}" DATE')
        else:
            col_defs.append(f'"{fname}" TEXT')

    cols_sql = ",\n               ".join(col_defs)

    # Build INSERT with real fields
    field_names = [f[0] for f in fields]
    placeholders = ", ".join(["?" for _ in field_names])
    insert_cols = ", ".join(field_names)
    insert_vals = ", ".join([f"data.get('{f}')" for f in field_names])

    # Build search — pick first text field
    search_field = next((f[0] for f in fields if f[2] == "text"), "name")

    # Randomly add enhancements each cycle for uniqueness
    enhancements = []
    if random.random() > 0.5:
        enhancements.append("search")
    if random.random() > 0.6:
        enhancements.append("stats")
    if random.random() > 0.7:
        enhancements.append("validation")

    search_route = ""
    if "search" in enhancements:
        search_route = f"""
@app.route('/api/{table_name}/search', methods=['GET'])
def search_{table_name}():
    q = request.args.get('q', '')
    db = get_db()
    items = db.execute(
        'SELECT * FROM {table_name} WHERE {search_field} LIKE ?',
        (f'%{{q}}%',)
    ).fetchall()
    return jsonify([dict(i) for i in items])
"""

    stats_route = ""
    if "stats" in enhancements:
        stats_route = f"""
@app.route('/api/{table_name}/stats', methods=['GET'])
def stats_{table_name}():
    db = get_db()
    total = db.execute('SELECT COUNT(*) as c FROM {table_name}').fetchone()['c']
    return jsonify({{'total': total, 'entity': '{entity}'}})
"""

    validation = ""
    if "validation" in enhancements:
        validation = f"""
    required_fields = {json.dumps(field_names[:2])}
    for rf in required_fields:
        if not data.get(rf):
            return jsonify({{'error': f'{{rf}} is required'}}), 400
"""

    return f'''import os
import sqlite3
from datetime import datetime
from flask import Flask, request, jsonify, g
from flask_cors import CORS
from werkzeug.security import generate_password_hash, check_password_hash
import jwt

app = Flask(__name__)
CORS(app)
app.config['SECRET_KEY'] = os.environ.get('SECRET_KEY', 'change-in-production')
app.config['DATABASE'] = 'app.db'

def get_db():
    db = getattr(g, '_database', None)
    if db is None:
        db = g._database = sqlite3.connect(app.config['DATABASE'])
        db.row_factory = sqlite3.Row
    return db

@app.teardown_appcontext
def close_db(error):
    db = getattr(g, '_database', None)
    if db is not None:
        db.close()

def init_db():
    db = get_db()
    db.execute("""CREATE TABLE IF NOT EXISTS users (
               id INTEGER PRIMARY KEY AUTOINCREMENT,
               email TEXT UNIQUE NOT NULL,
               username TEXT UNIQUE NOT NULL,
               password_hash TEXT NOT NULL,
               role TEXT DEFAULT 'user',
               created_at DATETIME DEFAULT CURRENT_TIMESTAMP
               )""")
    db.execute("""CREATE TABLE IF NOT EXISTS {table_name} (
               id INTEGER PRIMARY KEY AUTOINCREMENT,
               {cols_sql},
               status TEXT DEFAULT 'active',
               created_at DATETIME DEFAULT CURRENT_TIMESTAMP
               )""")
    db.commit()

@app.route('/api/health', methods=['GET'])
def health():
    return jsonify({{'status': 'healthy', 'app': '{cfg["name"]}', 'timestamp': datetime.now().isoformat()}})

@app.route('/api/auth/register', methods=['POST'])
def register():
    data = request.get_json()
    db = get_db()
    if db.execute('SELECT id FROM users WHERE email = ?', (data['email'],)).fetchone():
        return jsonify({{'error': 'Email exists'}}), 409
    pw = generate_password_hash(data['password'])
    cursor = db.execute('INSERT INTO users (email, username, password_hash) VALUES (?, ?, ?)',
                       (data['email'], data.get('username', data['email']), pw))
    db.commit()
    return jsonify({{'message': 'User created', 'user_id': cursor.lastrowid}}), 201

@app.route('/api/auth/login', methods=['POST'])
def login():
    data = request.get_json()
    db = get_db()
    user = db.execute('SELECT * FROM users WHERE email = ?', (data.get('username',''),)).fetchone()
    if user and check_password_hash(user['password_hash'], data.get('password','')):
        token = jwt.encode({{'user_id': user['id']}}, app.config['SECRET_KEY'], algorithm='HS256')
        return jsonify({{'token': token, 'user': dict(user)}})
    return jsonify({{'error': 'Invalid credentials'}}), 401

@app.route('/api/{table_name}', methods=['GET'])
def get_{table_name}():
    db = get_db()
    items = db.execute('SELECT * FROM {table_name} ORDER BY created_at DESC').fetchall()
    return jsonify([dict(i) for i in items])

@app.route('/api/{table_name}', methods=['POST'])
def create_{table_name}():
    data = request.get_json()
    db = get_db()
{validation}
    cursor = db.execute(
        'INSERT INTO {table_name} ({insert_cols}) VALUES ({placeholders})',
        ({insert_vals},)
    )
    db.commit()
    return jsonify({{'id': cursor.lastrowid, 'message': '{entity} created'}}), 201

@app.route('/api/{table_name}/<int:item_id>', methods=['GET'])
def get_{entity.lower()}(item_id):
    db = get_db()
    item = db.execute('SELECT * FROM {table_name} WHERE id = ?', (item_id,)).fetchone()
    if not item:
        return jsonify({{'error': 'Not found'}}), 404
    return jsonify(dict(item))

@app.route('/api/{table_name}/<int:item_id>', methods=['PUT'])
def update_{entity.lower()}(item_id):
    data = request.get_json()
    db = get_db()
    updates = ", ".join([f"{f[0]} = ?" for f in {repr(fields)}])
    vals = [data.get(f[0]) for f in {repr(fields)}] + [item_id]
    db.execute(f'UPDATE {table_name} SET {{updates}} WHERE id = ?', vals)
    db.commit()
    return jsonify({{'message': '{entity} updated'}})

@app.route('/api/{table_name}/<int:item_id>', methods=['DELETE'])
def delete_{entity.lower()}(item_id):
    db = get_db()
    db.execute('DELETE FROM {table_name} WHERE id = ?', (item_id,))
    db.commit()
    return jsonify({{'message': '{entity} deleted'}})
{search_route}
{stats_route}

if __name__ == '__main__':
    with app.app_context():
        init_db()
    app.run(host='0.0.0.0', port=5000, debug=True)
'''

def build_frontend(cfg):
    """Build a React frontend that actually uses the domain fields and calls the API"""
    name = cfg.get("name", "App")
    entity = cfg.get("entity", "Record")
    entities = cfg.get("entities", "Records")
    fields = cfg.get("fields", [])
    table_name = entities.lower().replace(" ", "_")
    nav = cfg.get("nav", [])
    icon = cfg.get("icon", "🏢")

    # Build form fields JSX
    form_fields_jsx = "\n".join([
        f"""          <TextField label="{f[1]}" type="{f[2]}" fullWidth margin="normal"
            value={{formData.{f[0]} || ''}}
            onChange={{e => setFormData({{...formData, {f[0]}: e.target.value}})}}/> """
        for f in fields
    ])

    # Build table headers
    table_cols = cfg.get("table_cols", fields[:4])
    headers_jsx = "\n".join([f'              <th style={{{{padding:"8px",textAlign:"left"}}}}>{c[1] if len(c)>1 else c[0]}</th>' for c in table_cols])
    cells_jsx = "\n".join(["              <td style={{padding:\"8px\"}}>{row." + c[0] + "}</td>" for c in table_cols])

    # Build nav items
    nav_jsx = "\n".join([

        # Write real frontend
        (path / "frontend" / "src" / "App.js").write_text(build_frontend(cfg))

        # index.js
        (path / "frontend" / "src" / "index.js").write_text(
            "import React from 'react';\nimport ReactDOM from 'react-dom/client';\nimport App from './App';\n"
            "const root = ReactDOM.createRoot(document.getElementById('root'));\n"
            "root.render(<React.StrictMode><App /></React.StrictMode>);\n"
        )

        # index.html
        (path / "frontend" / "public" / "index.html").write_text(
            f'<!DOCTYPE html><html><head><meta charset="utf-8"/><title>{cfg["name"]}</title></head>'
            '<body><div id="root"></div></body></html>'
        )

        # package.json — no MUI needed, pure inline styles
        (path / "frontend" / "package.json").write_text(json.dumps({
            "name": domain_id,
            "version": "1.0.0",
            "dependencies": {
                "react": "^18.2.0",
                "react-dom": "^18.2.0",
                "react-scripts": "5.0.1"
            },
            "scripts": {"start": "react-scripts start", "build": "react-scripts build"}
        }, indent=2))

        return app_id

    def life_cycle(self):
        configs = load_configs()
        domain_ids = list(configs.keys())

        while self.running:
            print(f"\n[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]")
            print("="*60)
            print(f"♻️  LIFE CYCLE {self.cycles}")
            print("="*60)
            print("💨 BREATHING IN - Scanning environment...")
            time.sleep(1)

            # Reload configs so live edits take effect
            configs = load_configs()
            domain_ids = list(configs.keys())

            print("🔬 DIGESTING - Loading domain configs...")
            print(f"    Domains loaded: {len(domain_ids)}")
            print("🧠 THINKING - Selecting domain...")
            time.sleep(1)

            domain_id = domain_ids[self.cycles % len(domain_ids)]
            cfg = configs[domain_id]
            print(f"    Selected: {cfg.get('icon','')} {cfg['name']}")
            print("🌟 BREATHING OUT - Creating evolved application...")

            app_id = self.generate_app(domain_id, cfg)
            print(f"    ✅ Generated: {app_id}")
            print(f"    📂 Domain: {cfg['name']} | Fields: {len(cfg.get('fields',[]))}")

            self.cycles += 1
            self.projects_created += 1
            save_state({"cycles": self.cycles, "projects_created": self.projects_created})

            print(f"    Total cycles: {self.cycles} | Projects: {self.projects_created}")
            print("💤 Resting for 300 seconds...")
            time.sleep(300)

if __name__ == "__main__":
    org = AutonomousOrganism()
    org.life_cycle()
